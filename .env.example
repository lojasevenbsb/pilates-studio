# MongoDB — credenciais do root (usadas apenas na inicialização do container)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=senha_forte@123
MONGO_INITDB_DATABASE=pilates

# URI usada pela aplicação dentro do Docker (hostname "mongo" = service name do compose)
MONGODB_URI=mongodb://pilates_app:senha_forte@123@mongo:27017/pilates?authSource=pilates

# ── Desenvolvimento local (fora do Docker) ────────────────────────────────────
# Copie para .env.local e ajuste conforme seu ambiente:
# MONGODB_URI=mongodb://localhost:27017/pilates
